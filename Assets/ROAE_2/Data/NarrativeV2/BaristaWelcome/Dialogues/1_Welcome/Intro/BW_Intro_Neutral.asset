  m_Script: {fileID: 11500000, guid: 36e87a4f269af074e86ec25091a07134, type: 3}
  m_Name: BW_Intro_Neutral
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueLines:
  - Speaker: Barista
    Text: Hello. What can I get for you today?
  - Speaker: Rina
    Text: Hi... I am still figuring that out.
  - Speaker: Barista
    Text: That is fair. First visits can feel a little disorienting in here.
  - Speaker: Rina
    Text: You noticed?
  - Speaker: Barista
    Text: I notice most things.
  - Speaker: Rina
    Text: I do not have anything to pay you with.
  - Speaker: Barista
    Text: Then let me start you with something simple. A photosynthetic sap, on the
      house.
  choices:
  - choiceText: Alright. Thank you.
    nextDialogue: {fileID: 11400000, guid: c7ca3744014f1e94e8ecbb7d78bdbdb6, type: 2}
