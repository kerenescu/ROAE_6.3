  m_Script: {fileID: 11500000, guid: 36e87a4f269af074e86ec25091a07134, type: 3}
  m_Name: BW_Intro_Mischievous
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueLines:
  - Speaker: Barista
    Text: Hello there. What can I get for you today?
  - Speaker: Rina
    Text: Hi... um... it is my first time here. Do you have a menu?
  - Speaker: Barista
    Text: Really? I could have sworn this was not the first time you had seen me.
  - Speaker: Barista
    Text: I mean... the first time I have seen you.
  - Speaker: Rina
    Text: ...
  - Speaker: Rina
    Text: I do not have anything to pay you with.
  - Speaker: Barista
    Text: You are funny. I like you already.
  - Speaker: Rina
    Text: ...
  - Speaker: Barista
    Text: Then let me prepare you a photosynthetic sap. Something to make sure you
      come back a second time, alright?
  choices:
  - choiceText: Sure.
    nextDialogue: {fileID: 11400000, guid: 9108f9cb362261c49bebc901c45b9833, type: 2}
    statEffect:
      creativity: 0
      empathy: 0
      plantCorruption: 0
