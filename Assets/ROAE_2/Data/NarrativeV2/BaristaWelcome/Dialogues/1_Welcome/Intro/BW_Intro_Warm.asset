  m_Script: {fileID: 11500000, guid: 36e87a4f269af074e86ec25091a07134, type: 3}
  m_Name: BW_Intro_Warm
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueLines:
  - Speaker: Barista
    Text: Hello. You look like you could use a quiet place for a minute.
  - Speaker: Rina
    Text: Is it that obvious?
  - Speaker: Barista
    Text: Only if you have been carrying too much alone.
  - Speaker: Rina
    Text: ...
  - Speaker: Rina
    Text: I do not have anything to pay you with.
  - Speaker: Barista
    Text: Then do not. Let me make you a photosynthetic sap. Consider it a welcome.
  choices:
  - choiceText: Thank you. I would like that.
    nextDialogue: {fileID: 11400000, guid: ed493a7dce613834abe0d4544b043b2c, type: 2}
    statEffect:
      creativity: -20
      empathy: 40
      plantCorruption: 50
    relationshipEffect:
      npcId: barista
      amount: 0
    extraEffects:
    - {fileID: 11400000, guid: ae4f3e7b9e4c92b49bfe27d20cd5cf00, type: 2}
    - {fileID: 11400000, guid: 2b8f0f3d515bf544089c0d76715abd49, type: 2}
    - {fileID: 11400000, guid: ff7fc9c9988561f4faa6dd67c4f8ad31, type: 2}
  - choiceText: That is kind, but I would rather wait.
    nextDialogue: {fileID: 0}
