  m_Script: {fileID: 11500000, guid: 36e87a4f269af074e86ec25091a07134, type: 3}
  m_Name: BW3_Intro_Mischievous
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueLines:
  - Speaker: Barista
    Text: Well. Either the cards were generous, or you're planning something.
  - Speaker: Rina
    Text: Maybe both.
  - Speaker: Barista
    Text: Good. I was worried the evening had gone dull.
  - Speaker: Barista
    Text: So which version of you came back to the counter?
  choices:
  - choiceText: The one still listening.
    nextDialogue: {fileID: 11400000, guid: 0cb28abef1b94a24a6c608b10b8f4f06, type: 2}
    statEffect:
      creativity: 1
      empathy: 0
      plantCorruption: 0
    relationshipEffect:
      npcId: barista
      amount: 1
    extraEffects:
    - {fileID: 11400000, guid: ff7fc9c9988561f4faa6dd67c4f8ad31, type: 2}
    - {fileID: 11400000, guid: 5b32c24a0ae74396b23da71ddde0a101, type: 2}
    - {fileID: 11400000, guid: 5b32c24a0ae74396b23da71ddde0a102, type: 2}
  - choiceText: The one who thinks cards are just expensive theatre.
    nextDialogue: {fileID: 11400000, guid: 0cb28abef1b94a24a6c608b10b8f4f06, type: 2}
    statEffect:
      creativity: 0
      empathy: -1
      plantCorruption: 1
    relationshipEffect:
      npcId: barista
      amount: -1
    extraEffects:
    - {fileID: 11400000, guid: ff7fc9c9988561f4faa6dd67c4f8ad31, type: 2}
    - {fileID: 11400000, guid: 5b32c24a0ae74396b23da71ddde0a101, type: 2}
    - {fileID: 11400000, guid: 5b32c24a0ae74396b23da71ddde0a103, type: 2}
  - choiceText: The one wondering whether you'd flinch if I repeated the part about you.
    nextDialogue: {fileID: 11400000, guid: 0cb28abef1b94a24a6c608b10b8f4f06, type: 2}
    statEffect:
