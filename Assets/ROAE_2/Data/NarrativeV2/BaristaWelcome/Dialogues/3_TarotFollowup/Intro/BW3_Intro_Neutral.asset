  m_Script: {fileID: 11500000, guid: 36e87a4f269af074e86ec25091a07134, type: 3}
  m_Name: BW3_Intro_Neutral
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueLines:
  - Speaker: Barista
    Text: You came back from Madame Lichenia looking like the room moved a little.
  - Speaker: Rina
    Text: It might have.
  - Speaker: Barista
    Text: That happens after people sit at her table.
  - Speaker: Barista
    Text: Do you want to say what the cards gave you, or just order something and pretend they missed?
  choices:
  - choiceText: She said something that stayed with me.
    nextDialogue: {fileID: 11400000, guid: 0cb28abef1b94a24a6c608b10b8f4f04, type: 2}
    statEffect:
      creativity: 1
      empathy: 1
      plantCorruption: 0
    relationshipEffect:
      npcId: barista
      amount: 2
    extraEffects:
    - {fileID: 11400000, guid: ff7fc9c9988561f4faa6dd67c4f8ad31, type: 2}
    - {fileID: 11400000, guid: 5b32c24a0ae74396b23da71ddde0a101, type: 2}
    - {fileID: 11400000, guid: 5b32c24a0ae74396b23da71ddde0a102, type: 2}
  - choiceText: Maybe later. I'm still deciding what I think.
    nextDialogue: {fileID: 11400000, guid: 0cb28abef1b94a24a6c608b10b8f4f04, type: 2}
    statEffect:
      creativity: 0
      empathy: 0
      plantCorruption: 0
    relationshipEffect:
      npcId: barista
      amount: 0
    extraEffects:
    - {fileID: 11400000, guid: ff7fc9c9988561f4faa6dd67c4f8ad31, type: 2}
    - {fileID: 11400000, guid: 5b32c24a0ae74396b23da71ddde0a101, type: 2}
    - {fileID: 11400000, guid: 5b32c24a0ae74396b23da71ddde0a103, type: 2}
  - choiceText: What if they were about you?
    nextDialogue: {fileID: 11400000, guid: 0cb28abef1b94a24a6c608b10b8f4f04, type: 2}
    statEffect:
      creativity: 1
