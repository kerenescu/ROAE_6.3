  m_Script: {fileID: 11500000, guid: 36e87a4f269af074e86ec25091a07134, type: 3}
  m_Name: BW3_Intro_Warm
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueLines:
  - Speaker: Barista
    Text: You seem quieter than before.
  - Speaker: Rina
    Text: I let Madame Lichenia read the cards.
  - Speaker: Barista
    Text: And?
  - Speaker: Rina
    Text: And now everything feels a little closer to the surface.
  - Speaker: Barista
    Text: Then let's not rush you.
  choices:
  - choiceText: She was kinder than I expected.
    nextDialogue: {fileID: 11400000, guid: 0cb28abef1b94a24a6c608b10b8f4f05, type: 2}
    statEffect:
      creativity: 0
      empathy: 1
      plantCorruption: 0
    relationshipEffect:
      npcId: barista
      amount: 2
    extraEffects:
    - {fileID: 11400000, guid: ff7fc9c9988561f4faa6dd67c4f8ad31, type: 2}
    - {fileID: 11400000, guid: 5b32c24a0ae74396b23da71ddde0a101, type: 2}
    - {fileID: 11400000, guid: 5b32c24a0ae74396b23da71ddde0a102, type: 2}
  - choiceText: I'm fine. I'd rather not unpack it.
    nextDialogue: {fileID: 11400000, guid: 0cb28abef1b94a24a6c608b10b8f4f05, type: 2}
    statEffect:
      creativity: 0
      empathy: 0
      plantCorruption: 0
    relationshipEffect:
      npcId: barista
      amount: -1
    extraEffects:
    - {fileID: 11400000, guid: ff7fc9c9988561f4faa6dd67c4f8ad31, type: 2}
    - {fileID: 11400000, guid: 5b32c24a0ae74396b23da71ddde0a101, type: 2}
    - {fileID: 11400000, guid: 5b32c24a0ae74396b23da71ddde0a103, type: 2}
  - choiceText: Depends. Do you want the safe version or the interesting one?
    nextDialogue: {fileID: 11400000, guid: 0cb28abef1b94a24a6c608b10b8f4f05, type: 2}
    statEffect:
