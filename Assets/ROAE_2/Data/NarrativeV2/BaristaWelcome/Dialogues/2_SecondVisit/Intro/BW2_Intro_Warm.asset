  m_Name: BW2_Intro_Warm
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueLines:
  - Speaker: Barista
    Text: I was hoping you would come back.
  - Speaker: Rina
    Text: You say that to everybody?
  - Speaker: Barista
    Text: No. Only to the ones who look less lost the second time.
  - Speaker: Rina
    Text: That obvious, huh?
  - Speaker: Barista
    Text: A little. Sit with me for a second and tell me what you want today.
  choices:
  - choiceText: Alright. Show me what you recommend.
    nextDialogue: {fileID: 11400000, guid: a1b3d6f0e4c24138b9f17b7c1c2d3005, type: 2}
    statEffect:
      creativity: 0
      empathy: 0
      plantCorruption: 0
    relationshipEffect:
      npcId: 
      amount: 0
    extraEffects:
    - {fileID: 11400000, guid: ae4f3e7b9e4c92b49bfe27d20cd5cf00, type: 2}
    - {fileID: 11400000, guid: ff7fc9c9988561f4faa6dd67c4f8ad31, type: 2}
  - choiceText: Maybe I only came back for the quiet.
    nextDialogue: {fileID: 0}
