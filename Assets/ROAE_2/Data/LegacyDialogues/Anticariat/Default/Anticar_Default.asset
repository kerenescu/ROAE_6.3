  m_Script: {fileID: 11500000, guid: 36e87a4f269af074e86ec25091a07134, type: 3}
  m_Name: Anticar_Default
  m_EditorClassIdentifier: 
  dialogueLines:
  - Speaker: Rina
    Text: "ave\u021Bi ni\u0219te broa\u0219te imense pe aici..."
  - Speaker: Anticar
    Text: "Gilbert vrei s\u0103 zici? da, e broasca mea!"
  - Speaker: Rina
    Text: "nu \xEE\u021Bi e fric\u0103 de faptul c\u0103 s-ar putea s\u0103 te m\u0103n\xE2nce?"
  - Speaker: Anticar
    Text: "cum s\u0103 \xEEmi fie fric\u0103? Gilbert m\u0103n\xE2nc\u0103 musculi\u021Be,
      nu plante"
  - Speaker: Rina
    Text: "atunci... ar trebui s\u0103 \xEE\u021Bi fie fric\u0103 de mine!"
  - Speaker: Rina
    Text: "sunt vegan\u0103"
  - Speaker: Rina
    Text: "m\u0103n\xE2nc EXCLUSIV plante"
  - Speaker: Anticar
    Text: "nu te umfla \xEEn pene"
  - Speaker: Anticar
    Text: "\u0219i eu m\u0103n\xE2nc DOAR plante"
  - Speaker: Rina
    Text: ...
  - Speaker: Rina
    Text: "nu s-ar cataloga drept... \nCANIBALISM?"
  - Speaker: Anticar
    Text: "nu \xEEmi place s\u0103 pun etichete, Rina"
  - Speaker: Rina
    Text: ...!!!
  - Speaker: Rina
    Text: "\xEEn fine.... Gilbert a fugit"
  - Speaker: Anticar
    Text: "\u0218I ABIA ACUM \xCEMI SPUI???"
  choices: []
