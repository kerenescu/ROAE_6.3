  - contactName: Leo
    messages:
    - sender: Leo
      content: "Heii, scuze c\u0103 te deranjez aiurea, dar tu ai f\u0103cut info,
        nu?"
      isOldConversation: 0
      hasChoices: 0
      responseOptions: []
    - sender: Rina
