  m_Script: {fileID: 11500000, guid: 3613c776760828941ae44cea35ff97bd, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  front: {fileID: 3803326287540965135}
  back: {fileID: 2711344616744131018}
  interpretation: "Tsk, tsk. Istoria se repet\u0103, darling. A fost odat\u0103 un
    alt artist care a ignorat semnele.\nA construit sus, prea sus\u2026 \u0219i c\xE2nd
    a venit furtuna, n-a \u0219tiut ce-l love\u0219te.\nAtunci c\u0103nd au \xEEnceput
    s\u0103 \xEEi s\xE2ngereze tablourile...\nAi grij\u0103. C\xE2nd totul se pr\u0103bu\u0219e\u0219te,
    nu uita cine erai \xEEnainte de ruine."
  freezeSeconds: 2.5
