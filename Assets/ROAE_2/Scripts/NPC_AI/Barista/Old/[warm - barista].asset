  dialogueLines:
  - Speaker: Barista
    Text: Sit, if you like.
  - Speaker: Rina
    Text: The world is already doing enough damage without forcing you to remain
      upright through all of it.
  choices:
  - choiceText: That is kinder than I expected.
    nextDialogue: {fileID: 11400000, guid: 4509f7dd12b93d64db04af99d80802c7, type: 2}
