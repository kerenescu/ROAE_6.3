  m_Name: '[neutral - barista]'
  m_EditorClassIdentifier: 
  dialogueLines:
  - Speaker: Barista
    Text: You wear composure like a borrowed coat.
  - Speaker: Rina
    Text: It fits well enough from a distance. Up close, the seams are pleading.
  choices:
  - choiceText: I was hoping you might understand.
    nextDialogue: {fileID: 11400000, guid: 4509f7dd12b93d64db04af99d80802c7, type: 2}
    statEffect:
      creativity: 0
      empathy: 0
      plantCorruption: 0
    relationshipEffect:
      npcId: barista
      amount: 2
  - choiceText: I do not need comfort. I need answers.
    nextDialogue: {fileID: 11400000, guid: 7c06c13eb8125c44a885be3bb430789d, type: 2}
