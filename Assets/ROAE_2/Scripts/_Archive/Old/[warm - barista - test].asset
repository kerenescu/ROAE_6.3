  dialogueLines:
  - Speaker: Barista
    Text: You look tired in the old, sacred way.
  - Speaker: Rina
    Text: Not sleepy. Soul-tired. The sort of tired that coffee salutes and then
      quietly fails to cure.
  choices:
  - choiceText: Thank you. I needed that.
    nextDialogue: {fileID: 11400000, guid: 4509f7dd12b93d64db04af99d80802c7, type: 2}
    statEffect:
      creativity: 0
      empathy: 0
      plantCorruption: 0
    relationshipEffect:
      npcId: barista
      amount: 2
  - choiceText: I did not come here to be read.
    nextDialogue: {fileID: 11400000, guid: 7c06c13eb8125c44a885be3bb430789d, type: 2}
