  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 36e87a4f269af074e86ec25091a07134, type: 3}
  m_Name: barista_guarded_hint_generated
  m_EditorClassIdentifier: 
  dialogueLines:
  - Speaker: Barista
    Text: You are asking dangerous questions with the confidence of someone who has
      not yet paid for them.
  - Speaker: Rina
    Text: Then give me a direction, not absolution.
  choices:
  - choiceText: Fine. A direction is enough. I can manage the rest without trampling
      anyone.
    nextDialogue: {fileID: 11400000, guid: 57dfffb685d0717409ae05675deddec7, type: 2}
    statEffect:
      creativity: 0
      empathy: 1
      plantCorruption: 0
    relationshipEffect:
      npcId: barista
      amount: 2
  - choiceText: Tell me what detail people keep cleaning. Fear always leaves a shine.
    nextDialogue: {fileID: 11400000, guid: 17c0cbeb5c1e1c841b7edd58756c4b0c, type: 2}
    statEffect:
      creativity: 10
      empathy: 0
      plantCorruption: 0
    relationshipEffect:
      npcId: barista
      amount: 1
  - choiceText: You make secrecy sound theatrical. I am not here for theater.
    nextDialogue: {fileID: 11400000, guid: f46e7647486451e4da536350747bce8e, type: 2}
    statEffect:
      creativity: 0
      empathy: -1
      plantCorruption: 0
    relationshipEffect:
      npcId: barista
      amount: -2
