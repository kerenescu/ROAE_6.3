  m_Script: {fileID: 11500000, guid: 36e87a4f269af074e86ec25091a07134, type: 3}
  m_Name: barista_warm_hint_generated
  m_EditorClassIdentifier: 
  dialogueLines:
  - Speaker: Barista
    Text: You seem earnest, which is either admirable or catastrophic.
  - Speaker: Rina
    Text: Then spare me one mistake and let me earn the rest myself.
  choices:
  - choiceText: I will be careful with whoever is caught in this before I am careful
      with myself.
    nextDialogue: {fileID: 11400000, guid: 29bf957a44bd63b4a86fd695cd963c3b, type: 2}
    statEffect:
      creativity: 0
      empathy: 1
      plantCorruption: 0
    relationshipEffect:
      npcId: barista
      amount: 2
  - choiceText: Point me toward the mark, the pattern, the stain that repeats.
    nextDialogue: {fileID: 11400000, guid: 3dd555ccc35a3db48994eb2f2e835499, type: 2}
    statEffect:
      creativity: 10
      empathy: 0
      plantCorruption: 0
    relationshipEffect:
      npcId: barista
      amount: 1
  - choiceText: If hesitation is the trap, then maybe I should stop hesitating.
    nextDialogue: {fileID: 11400000, guid: e58d9a7dd23814847a4e787feb130b65, type: 2}
    statEffect:
      creativity: 0
      empathy: 0
      plantCorruption: 1
    relationshipEffect:
      npcId: barista
      amount: -1
