  m_Script: {fileID: 11500000, guid: 36e87a4f269af074e86ec25091a07134, type: 3}
  m_Name: barista_neutral_generated
  m_EditorClassIdentifier: 
  dialogueLines:
  - Speaker: Barista
    Text: You wear composure like a borrowed coat.
  - Speaker: Rina
    Text: It fits well enough from a distance. Up close, the seams are pleading.
  choices:
  - choiceText: I was hoping someone here might understand.
    nextDialogue: {fileID: 11400000, guid: e734972d234cd974eb902b28f93420a1, type: 2}
    statEffect:
      creativity: 0
      empathy: 1
      plantCorruption: 0
    relationshipEffect:
      npcId: barista
      amount: 2
  - choiceText: Then tell me what in this room is lying first.
    nextDialogue: {fileID: 11400000, guid: a40e419a93670aa438641e9ba590bdcd, type: 2}
    statEffect:
      creativity: 10
      empathy: 0
      plantCorruption: 0
    relationshipEffect:
      npcId: barista
      amount: 1
  - choiceText: If the place wants something from me, I would rather hear it directly.
    nextDialogue: {fileID: 11400000, guid: 2f3542257e9a9d84b9edcca3320d5e68, type: 2}
    statEffect:
      creativity: 0
      empathy: 0
      plantCorruption: 1
    relationshipEffect:
      npcId: barista
      amount: -1
